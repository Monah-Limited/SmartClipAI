#!/usr/bin/env bash
# ============================================================================
# SmartClipAI CLI — Command line interface for SmartClipAI
# ============================================================================
# Usage:
#   smartclipai help          Show this help
#   smartclipai start         Launch SmartClipAI.app
#   smartclipai stop          Quit SmartClipAI
#   smartclipai status        Check if SmartClipAI is running
#   smartclipai config        Show current API key status
#   smartclipai config set <key>  Set DeepSeek API key
#   smartclipai translate <text>  Quick translate via CLI
#   smartclipai rewrite <text>    Quick rewrite via CLI
#   smartclipai version       Show version
# ============================================================================

set -euo pipefail

APP_NAME="SmartClipAI"
APP_PATH="/Applications/$APP_NAME.app"
PYTHON=""
KEYCHAIN_ACCOUNT="SmartClipAI"
KEYCHAIN_SERVICE="com.smartclipai.apikey"
DEEPSEEK_API_URL="https://api.deepseek.com/v1/chat/completions"
DEEPSEEK_MODEL="deepseek-chat"
VERSION="1.0.0"

# ── Find Python ─────────────────────────────────────────────────────────────
find_python() {
    for py in "/opt/homebrew/bin/python3.11" "/opt/homebrew/bin/python3.12" \
              "/usr/local/bin/python3.11" "/opt/homebrew/bin/python3" \
              "/usr/bin/python3" "$HOME/.hermes/hermes-agent/venv/bin/python3"; do
        if [ -x "$py" ]; then
            PYTHON="$py"
            return 0
        fi
    done
    # Fallback to PATH
    PYTHON="$(command -v python3 2>/dev/null || true)"
    if [ -n "$PYTHON" ] && [ -x "$PYTHON" ]; then
        return 0
    fi
    return 1
}

# ── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { printf "${BLUE}%s${NC}\n" "$*"; }
ok()    { printf "${GREEN}✅ %s${NC}\n" "$*"; }
warn()  { printf "${YELLOW}⚠️  %s${NC}\n" "$*"; }
error() { printf "${RED}❌ %s${NC}\n" "$*"; }

# ── Help ────────────────────────────────────────────────────────────────────
show_help() {
    cat <<EOF
${CYAN}SmartClipAI v${VERSION}${NC} — AI-powered clipboard assistant for macOS

${BLUE}Usage:${NC}
  smartclipai <command> [options]

${BLUE}Commands:${NC}
  help                          Show this help
  start                         Launch SmartClipAI.app in menu bar
  stop                          Quit the SmartClipAI app
  restart                       Restart SmartClipAI
  status                        Check if SmartClipAI is running
  install                       Install SmartClipAI (from current directory)
  uninstall                     Remove SmartClipAI completely

${BLUE}Configuration:${NC}
  config                        Show API key status
  config set <key>              Set DeepSeek API key in macOS Keychain
  config delete                 Remove API key from Keychain

${BLUE}Quick Actions (no GUI needed):${NC}
  translate <text>              Translate text to Chinese
  rewrite <text>                Polish and rewrite text
  summarize <text>              Summarize text

${BLUE}Examples:${NC}
  smartclipai config set sk-xxxxxxxxxxxx      # Set API key
  smartclipai translate "Hello world"          # Quick translate
  smartclipai status                           # Check if running

${BLUE}Install:${NC}
  curl -sfL https://raw.githubusercontent.com/monah-studio/SmartClipAI/main/scripts/install.sh | sh
EOF
}

# ── App Management ──────────────────────────────────────────────────────────

cmd_start() {
    if [ -d "$APP_PATH" ]; then
        # Bypass Gatekeeper for first launch
        xattr -dr com.apple.quarantine "$APP_PATH" 2>/dev/null || true
        open -n -g "$APP_PATH"
        ok "SmartClipAI launched! Look for the 📋 icon in your menu bar."
    else
        warn "SmartClipAI.app not found in /Applications"
        warn "Install first: smartclipai install"
    fi
}

cmd_stop() {
    PID=$(ps aux 2>/dev/null | grep "[S]martClipAI" | awk '{print $2}' | head -1 || true)
    if [ -n "$PID" ]; then
        kill "$PID" 2>/dev/null || true
        PYPID=$(ps aux 2>/dev/null | grep "[m]ain_script.py" | awk '{print $2}' | head -1 || true)
        [ -n "$PYPID" ] && kill "$PYPID" 2>/dev/null || true
        ok "SmartClipAI stopped."
    else
        warn "SmartClipAI is not running."
    fi
}

cmd_restart() {
    cmd_stop
    sleep 1
    cmd_start
}

cmd_status() {
    APP_PID=$(ps aux 2>/dev/null | grep "[S]martClipAI" | awk '{print $2}' | head -1 || true)
    PY_PID=$(ps aux 2>/dev/null | grep "[m]ain_script.py" | awk '{print $2}' | head -1 || true)

    echo "📋 SmartClipAI v$VERSION — Status"
    echo ""

    if [ -d "$APP_PATH" ]; then
        ok "App installed: $APP_PATH"
    else
        warn "App not installed. Run: smartclipai install"
    fi

    if [ -n "$APP_PID" ] || [ -n "$PY_PID" ]; then
        ok "Running (PID: ${APP_PID:-$PY_PID})"
    else
        warn "Not running. Start: smartclipai start"
    fi
}

cmd_install() {
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

    if [ -f "$PROJECT_DIR/dist/$APP_NAME.app/Contents/MacOS/$APP_NAME" ]; then
        info "Installing from local build..."
        rm -rf "$APP_PATH" 2>/dev/null || true
        cp -R "$PROJECT_DIR/dist/$APP_NAME.app" /Applications/
        xattr -dr com.apple.quarantine "$APP_PATH" 2>/dev/null || true
        spctl --add "$APP_PATH" 2>/dev/null || true
        ok "Installed from local build."
    else
        warn "No local .app found. Run web installer:"
        echo "  curl -sfL https://raw.githubusercontent.com/monah-studio/SmartClipAI/main/scripts/install.sh | sh"
    fi
}

cmd_uninstall() {
    info "Uninstalling SmartClipAI..."

    # Stop app
    cmd_stop 2>/dev/null || true

    # Remove from /Applications
    if [ -d "$APP_PATH" ]; then
        rm -rf "$APP_PATH"
        ok "Removed $APP_PATH"
    fi

    # Remove LaunchAgent if exists
    launchctl bootout gui/$(id -u) "$HOME/Library/LaunchAgents/com.timwynter.smartclipai.plist" 2>/dev/null || true
    rm -f "$HOME/Library/LaunchAgents/com.timwynter.smartclipai.plist"

    # Remove CLI
    if [ -f "/usr/local/bin/smartclipai" ]; then
        rm -f "/usr/local/bin/smartclipai"
        ok "Removed CLI: /usr/local/bin/smartclipai"
    fi
    if [ -f "$HOME/.local/bin/smartclipai" ]; then
        rm -f "$HOME/.local/bin/smartclipai"
        ok "Removed CLI: $HOME/.local/bin/smartclipai"
    fi

    # Ask about API key
    echo ""
    warn "API key is stored in macOS Keychain."
    echo "  To remove: security delete-generic-password -a \"$KEYCHAIN_ACCOUNT\" -s \"$KEYCHAIN_SERVICE\""
    echo ""

    ok "SmartClipAI uninstalled."
}

# ── Configuration ───────────────────────────────────────────────────────────

cmd_config() {
    if ! find_python; then
        error "Python 3 not found. Please install Python 3.8+."
    fi

    KEY=$($PYTHON -c "
import subprocess
r = subprocess.run(['security', 'find-generic-password', '-a', '$KEYCHAIN_ACCOUNT', '-s', '$KEYCHAIN_SERVICE', '-w'],
                   capture_output=True, text=True, timeout=5)
if r.returncode == 0:
    k = r.stdout.strip()
    print(k[:10] + '...' + k[-4:] if len(k) > 14 else k)
else:
    print('')
" 2>/dev/null || echo "")

    if [ -n "$KEY" ]; then
        ok "API Key: $KEY (stored in macOS Keychain)"
    else
        warn "No API Key set."
        info "Set one: smartclipai config set sk-your-key-here"
    fi
}

cmd_config_set() {
    if [ $# -lt 1 ]; then
        error "Usage: smartclipai config set <your-deepseek-api-key>"
    fi

    KEY="$1"
    if ! find_python; then
        error "Python 3 not found."
    fi

    $PYTHON -c "
import subprocess
subprocess.run(['security', 'delete-generic-password', '-a', '$KEYCHAIN_ACCOUNT', '-s', '$KEYCHAIN_SERVICE'],
               capture_output=True, text=True, timeout=5)
r = subprocess.run(['security', 'add-generic-password', '-a', '$KEYCHAIN_ACCOUNT', '-s', '$KEYCHAIN_SERVICE', '-w', '$KEY', '-U'],
                   capture_output=True, text=True, timeout=5)
exit(0 if r.returncode == 0 else 1)
" 2>/dev/null && ok "API Key saved to macOS Keychain" || error "Failed to save API Key"
}

cmd_config_delete() {
    if ! find_python; then
        error "Python 3 not found."
    fi

    $PYTHON -c "
import subprocess
subprocess.run(['security', 'delete-generic-password', '-a', '$KEYCHAIN_ACCOUNT', '-s', '$KEYCHAIN_SERVICE'],
               capture_output=True, text=True, timeout=5)
" 2>/dev/null
    ok "API Key deleted from Keychain"
}

# ── Quick AI Actions ────────────────────────────────────────────────────────

call_deepseek() {
    local prompt="$1"
    local system_msg="${2:-You are a helpful assistant.}"

    if ! find_python; then
        error "Python 3 not found."
    fi

    $PYTHON -c "
import subprocess, json, urllib.request, sys

r = subprocess.run(['security', 'find-generic-password', '-a', '$KEYCHAIN_ACCOUNT', '-s', '$KEYCHAIN_SERVICE', '-w'],
                   capture_output=True, text=True, timeout=5)
api_key = r.stdout.strip() if r.returncode == 0 else ''
if not api_key:
    print('⚠️  No API Key set. Run: smartclipai config set <your-key>')
    sys.exit(1)

data = json.dumps({
    'model': '$DEEPSEEK_MODEL',
    'messages': [
        {'role': 'system', 'content': $(python3 -c "import json; print(json.dumps(system_msg))")},
        {'role': 'user', 'content': $(python3 -c "import json; print(json.dumps(prompt))")}
    ],
    'temperature': 0.3,
    'max_tokens': 2000,
}).encode()

req = urllib.request.Request(
    '$DEEPSEEK_API_URL',
    data=data,
    headers={'Authorization': f'Bearer {api_key}', 'Content-Type': 'application/json'},
    method='POST',
)
try:
    with urllib.request.urlopen(req, timeout=30) as resp:
        result = json.loads(resp.read())
        print(result['choices'][0]['message']['content'])
except Exception as e:
    print(f'Error: {e}')
" 2>&1
}

cmd_translate() {
    [ $# -lt 1 ] && error "Usage: smartclipai translate <text>"
    echo ""
    info "🌍 Translating..."
    echo ""
    call_deepseek "Translate the following text to Chinese. Return only the translation:\n\n$*" "You are a professional translator."
}

cmd_rewrite() {
    [ $# -lt 1 ] && error "Usage: smartclipai rewrite <text>"
    echo ""
    info "✍️ Rewriting..."
    echo ""
    call_deepseek "Polish and improve the following text to make it more professional and fluent:\n\n$*" "You are a professional editor."
}

cmd_summarize() {
    [ $# -lt 1 ] && error "Usage: smartclipai summarize <text>"
    echo ""
    info "📝 Summarizing..."
    echo ""
    call_deepseek "Summarize the following text concisely in Chinese:\n\n$*" "You are a professional summarizer."
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
    case "${1:-help}" in
        help|-h|--help)
            show_help
            ;;
        start)
            cmd_start
            ;;
        stop)
            cmd_stop
            ;;
        restart)
            cmd_restart
            ;;
        status)
            cmd_status
            ;;
        install)
            cmd_install
            ;;
        uninstall)
            cmd_uninstall
            ;;
        config)
            case "${2:-}" in
                set)
                    shift 2
                    cmd_config_set "$@"
                    ;;
                delete|remove|rm)
                    cmd_config_delete
                    ;;
                *)
                    cmd_config
                    ;;
            esac
            ;;
        translate)
            shift
            cmd_translate "$@"
            ;;
        rewrite)
            shift
            cmd_rewrite "$@"
            ;;
        summarize)
            shift
            cmd_summarize "$@"
            ;;
        version|-v|--version)
            echo "SmartClipAI v$VERSION"
            ;;
        *)
            error "Unknown command: $1\nRun 'smartclipai help' for usage."
            ;;
    esac
}

main "$@"
